# Supabase 연동 (Phase 2 멀티플레이)
# 아래 값을 채우고 파일명을 .env.local 로 바꾼 뒤 dev 서버를 재시작하세요.
# 값이 없으면 앱은 자동으로 "혼자 달리기(솔로)" 모드로만 동작합니다.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# (선택) GA4 측정 ID — 없으면 트래킹 비활성(no-op).
# Google Analytics > 관리 > 데이터 스트림 > 웹 스트림에서 발급 (G-로 시작)
NEXT_PUBLIC_GA_ID=

# (선택) 카카오톡 공유 — JavaScript 키. 없으면 Web Share/링크 복사로 폴백됩니다.
# 카카오 개발자센터에서 앱 생성 후 JS 키 발급 + 사이트 도메인 등록 필요.
NEXT_PUBLIC_KAKAO_JS_KEY=
